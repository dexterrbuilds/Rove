# Public web configuration
NEXT_PUBLIC_PRIVY_APP_ID=
# Public key quorum ID (not the private key) from Privy Authorization Keys.
NEXT_PUBLIC_PRIVY_SIGNER_ID=
# Optional comma-separated policy IDs applied to the signer.
NEXT_PUBLIC_PRIVY_POLICY_IDS=
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_USSD_SHORTCODE=*384*1234#

# Express API configuration
PORT=3001
WEB_ORIGIN=http://localhost:3000
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# Required when the delegated signer is protected by a Privy authorization key.
# Use the P-256 private key downloaded/configured in the Privy dashboard.
PRIVY_AUTHORIZATION_PRIVATE_KEY=

# Use a separate random value of at least 32 characters. Configure Africa's Talking with:
# https://YOUR_API_HOST/ussd-blockchain?at_token=THIS_VALUE
AFRICASTALKING_USSD_CALLBACK_TOKEN=
AFRICASTALKING_USSD_SERVICE_CODE="*384*1234#"
# Optional comma-separated exact source IPs supplied by Africa's Talking support.
# Do not guess these values or copy unofficial IP lists.
AFRICASTALKING_USSD_ALLOWED_IPS=

# Keep frontend and backend on the same cluster/network.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CAIP2=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
