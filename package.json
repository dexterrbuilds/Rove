{
  "name": "rove",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "USSD access to self-custodial Solana wallets",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm:dev:web\" \"npm:dev:api\"",
    "dev:web": "next dev",
    "dev:api": "tsx watch server/index.ts",
    "build": "npm run build:web && npm run build:api",
    "build:web": "next build",
    "build:api": "tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "start:web": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:security:db": "vitest run server/security-db.integration.test.ts"
  },
  "dependencies": {
    "@privy-io/node": "latest",
    "@privy-io/react-auth": "latest",
    "@solana/web3.js": "latest",
    "@supabase/supabase-js": "latest",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "express-rate-limit": "latest",
    "framer-motion": "^12.42.2",
    "libphonenumber-js": "^1.13.9",
    "lucide-react": "latest",
    "next": "latest",
    "qrcode.react": "^4.2.0",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "0.35.3",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "concurrently": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "overrides": {
    "axios": "1.18.1",
    "postcss": "8.5.21",
    "sharp": "0.35.3",
    "shell-quote": "1.10.0",
    "uuid": "11.1.1",
    "ws": "8.21.1"
  },
  "engines": {
    "node": ">=20"
  }
}
